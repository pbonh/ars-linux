# Managed by ars-linux/profile_d
if command -v fzf >/dev/null 2>&1; then
    if [ -n "${BASH_VERSION:-}" ] && [ -f /usr/share/fzf/shell/key-bindings.bash ]; then
        source /usr/share/fzf/shell/key-bindings.bash
    elif [ -n "${ZSH_VERSION:-}" ] && [ -f /usr/share/fzf/shell/key-bindings.zsh ]; then
        source /usr/share/fzf/shell/key-bindings.zsh
    fi
fi
